---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Merci" lang="fr">
  <div style="text-align: center; padding: 4rem 2rem;">
    <h1 style="color: var(--color-navy); margin-bottom: 1rem;">Merci !</h1>
    <p style="font-size: 1.2rem; color: var(--color-dark-gray); margin-bottom: 2rem;">
      Nous avons reçu votre message et nous vous répondrons bientôt.
    </p>
    <a href="/fr/" style="color: var(--color-lime); text-decoration: none; font-weight: bold; font-size: 1.1rem;">
      ← Retour à l'accueil
    </a>
  </div>
</BaseLayout>
