---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro';

const newsItems = [
  {
    title: "Initiative Mondiale pour la Paix",
    date: "2024-04-05",
    description: "Rejoignez-nous dans notre dernière initiative pour promouvoir la paix et le dialogue entre les communautés."
  },
  {
    title: "Semaine de Sensibilisation à l'Accessibilité",
    date: "2024-03-28",
    description: "Célébrer les personnes en situation de handicap et leurs contributions à la société."
  }
];

const resourceItems = [
  {
    title: "Boîte à Outils pour la Paix",
    description: "Ressources complètes pour les initiatives de construction de la paix communautaire.",
    link: "#"
  },
  {
    title: "Ressources d'Accessibilité",
    description: "Outils et guides pour créer des environnements inclusifs.",
    link: "#"
  }
];

const rssItems = [
  {
    title: "L'ONU Appelle à des Actions pour la Paix",
    pubDate: "2024-04-05",
    description: "Les Nations Unies poursuivent leurs efforts pour promouvoir la paix mondiale...",
    link: "#"
  }
];

const translations = {
  news: 'Actualités & Événements',
  resources: 'Ressources',
  rss: 'Actualités Mondiales',
  contact: 'Nous Contacter',
  contactMessage: 'Des questions ? Nous serions heureux de vous entendre.',
  name: 'Nom',
  email: 'E-mail',
  message: 'Message',
  send: 'Envoyer'
};
---

<BaseLayout title="Accueil" lang="fr">
  <ThreeColumnLayout 
    lang="fr"
    newsItems={newsItems}
    resourceItems={resourceItems}
    rssItems={rssItems}
    translations={translations}
  />

  <div class="contact-section">
    <h2>{translations.contact}</h2>
    <p>{translations.contactMessage}</p>
    <form class="contact-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="96d22947-6743-4110-a441-8d5b1a3b7bcf" />
      <input type="hidden" name="subject" value="Nouveau Contact du Site Web PeaceAbility" />
      <input type="hidden" name="redirect" value="https://yourdomain.com/fr/merci" />

      <div class="form-group">
        <label for="name">{translations.name}</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div class="form-group">
        <label for="email">{translations.email}</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div class="form-group">
        <label for="message">{translations.message}</label>
        <textarea id="message" name="message" required></textarea>
      </div>

      <button type="submit">{translations.send}</button>
    </form>
  </div>
</BaseLayout>
