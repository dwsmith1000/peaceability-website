---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You" lang="en">
  <div style="text-align: center; padding: 4rem 2rem;">
    <h1 style="color: var(--color-navy); margin-bottom: 1rem;">Thank You!</h1>
    <p style="font-size: 1.2rem; color: var(--color-dark-gray); margin-bottom: 2rem;">
      We've received your message and will get back to you soon.
    </p>
    <a href="/en/" style="color: var(--color-lime); text-decoration: none; font-weight: bold; font-size: 1.1rem;">
      ← Back to Home
    </a>
  </div>
</BaseLayout>
